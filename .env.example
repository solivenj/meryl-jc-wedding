# RSVP -> Google Sheets (server-only; read by app/api/submit/route.ts).
# Copy to .env.local for local dev; set the same three in Vercel project env vars.

# Service account address (the "client_email" from the downloaded JSON key).
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# The "private_key" from that JSON key, in quotes. Newlines may be literal \n
# (as Vercel stores them) or real — the route handles both.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# The long token in the target spreadsheet's URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=the-long-id-from-the-sheet-url
